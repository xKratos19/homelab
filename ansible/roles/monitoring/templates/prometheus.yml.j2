global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'homelab-lxc'
    static_configs:
      - targets:
          - '192.168.1.130:9100'  # apps
          - '192.168.1.133:9100'  # n8n
          - '192.168.1.3:9100'    # adguard
          - '192.168.1.135:9100'  # jellyfin
          - '192.168.1.145:9100'  # wizarr
          - '192.168.1.150:9100'  # docker_testing
          - '192.168.1.136:9100'  # myspeed
          - '192.168.1.161:9100'  # lyrion
